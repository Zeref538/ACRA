# Set to "false" in production — requires valid Supabase JWTs
SKIP_AUTH=true

# Your Supabase JWT secret (Settings → API → JWT Secret)
# Required when SKIP_AUTH=false
SUPABASE_JWT_SECRET=

# Public URL where this backend is reachable (used to build image URLs)
# Locally: http://localhost:8000
# On Render: https://your-app.onrender.com
BASE_URL=http://localhost:8000

# How long before job images are deleted (hours)
JOB_EXPIRY_HOURS=24
