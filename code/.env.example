# ACRA backend configuration
# On Render: set these in the Render dashboard Environment tab (not a committed file).
# Locally: copy to code/.env and adjust as needed.

# Set to false in production — requires SUPABASE_JWT_SECRET to be set.
SKIP_AUTH=false

# Supabase JWT secret — Supabase project → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=

# Public base URL of this service — used to build image URLs returned by the API.
# Local:      http://localhost:8000
# Production: https://your-acra-backend.onrender.com
BASE_URL=http://localhost:8000

# Persistent data directory — set to /data on Render (matches the Disk mount).
# Leave blank locally (defaults to code/ directory).
DATA_DIR=

# Hours before a processed job and its images are purged.
JOB_EXPIRY_HOURS=24

# How often (seconds) the background task purges expired jobs.
PURGE_INTERVAL_SECONDS=3600

# Comma-separated frontend origins allowed by CORS.
# Production: your Vercel URL, e.g. https://acra.vercel.app
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional: override YOLO model path (default: acra_medium_v7_best.onnx, then best.pt)
# SEG_MODEL_PATH=acra_medium_v7_best.onnx
