# ACRA backend configuration — copy to code/.env and adjust as needed.

# Skip JWT verification (local dev). Set to false in production.
SKIP_AUTH=true

# Supabase JWT secret — required when SKIP_AUTH=false.
SUPABASE_JWT_SECRET=

# Public base URL used to build image links returned by the API.
BASE_URL=http://localhost:8000

# Hours before a processed job (and its images) expires and is purged.
JOB_EXPIRY_HOURS=24

# How often (seconds) the background task purges expired jobs.
PURGE_INTERVAL_SECONDS=3600

# Comma-separated list of allowed CORS origins (frontend URLs).
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
